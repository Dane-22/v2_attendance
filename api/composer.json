{
    "name": "jajr/attendance-api",
    "type": "project",
    "description": "JAJR Attendance and Payroll System API",
    "keywords": ["laravel", "api", "attendance", "payroll"],
    "license": "MIT",
    "require": {
        "php": "^8.0",
        "illuminate/database": "^9.0",
        "illuminate/routing": "^9.0",
        "illuminate/http": "^9.0",
        "illuminate/container": "^9.0",
        "illuminate/events": "^9.0",
        "illuminate/auth": "^9.0",
        "illuminate/support": "^9.0",
        "illuminate/validation": "^9.0",
        "illuminate/caching": "^9.0",
        "vlucas/phpdotenv": "^5.4",
        "firebase/php-jwt": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
