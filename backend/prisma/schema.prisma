generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Employee {
  id                   Int       @id @default(autoincrement())
  employeeCode         String?   @unique(map: "employee_code") @map("employee_code") @db.VarChar(50)
  firstName            String?   @map("first_name") @db.VarChar(100)
  middleName           String?   @map("middle_name") @db.VarChar(100)
  lastName             String?   @map("last_name") @db.VarChar(100)
  email                String?   @unique(map: "email") @db.VarChar(100)
  department           String?   @db.VarChar(50)
  position             String?   @db.VarChar(50)
  branchName           String?   @map("branch_name") @db.VarChar(100)
  status               String?   @default("Active") @db.VarChar(20)
  dailyRate            Decimal?  @default(0.00) @map("daily_rate") @db.Decimal(10, 2)
  hasDeductions        Boolean?  @default(false) @map("has_deductions")
  profileImage         String?   @map("profile_image") @db.VarChar(255)
  createdAt            DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt            DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  defaultBranchId      Int?      @map("default_branch_id")
  performanceAllowance Decimal?  @default(0.00) @map("performance_allowance") @db.Decimal(10, 2)
  hasDeduction         Boolean?  @default(true) @map("has_deduction")
  branchId             Int?      @map("branch_id")
  branchCode           String?   @map("branch_code") @db.VarChar(10)
  // pinHash              String?   @map("pin_hash") @db.VarChar(255)
  // pinSalt              String?   @map("pin_salt") @db.VarChar(255)

  @@index([branchName], map: "idx_employee_branch")
  @@index([branchCode], map: "idx_employee_branch_code")
  @@map("employees")
}

model Attendance {
  id          Int                @id @default(autoincrement())
  employeeId  Int                @map("employee_id")
  branch_code String?            @db.VarChar(10)
  date        DateTime           @db.Date
  check_in    DateTime?          @db.Time(0)
  check_out   DateTime?          @db.Time(0)
  status      attendance_status? @default(present)
  notes       String?            @db.Text
  createdAt   DateTime?          @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime?          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@map("attendance")
}

model PayrollRecord {
  id                    Int                     @id @default(autoincrement())
  employeeId            Int                     @map("employee_id")
  branch_code           String                  @db.VarChar(20)
  payroll_week_start    DateTime                @db.Date
  payroll_week_end      DateTime                @db.Date
  week_number           Int
  days_worked           Int?                    @default(0)
  daily_rate            Decimal?                @default(0.00) @db.Decimal(10, 2)
  basic_pay             Decimal?                @default(0.00) @db.Decimal(10, 2)
  overtimeHours         Decimal?                @default(0.00) @map("overtime_hours") @db.Decimal(5, 2)
  overtime_amount       Decimal?                @default(0.00) @db.Decimal(10, 2)
  performance_allowance Decimal?                @default(0.00) @db.Decimal(10, 2)
  grossPay              Decimal?                @default(0.00) @map("gross_pay") @db.Decimal(10, 2)
  sss_contribution      Decimal?                @default(0.00) @db.Decimal(10, 2)
  phic_contribution     Decimal?                @default(0.00) @db.Decimal(10, 2)
  hdmf_contribution     Decimal?                @default(0.00) @db.Decimal(10, 2)
  cash_advance          Decimal?                @default(0.00) @db.Decimal(10, 2)
  total_deductions      Decimal?                @default(0.00) @db.Decimal(10, 2)
  netPay                Decimal?                @default(0.00) @map("net_pay") @db.Decimal(10, 2)
  status                payroll_records_status? @default(draft)
  createdAt             DateTime?               @default(now()) @map("created_at") @db.Timestamp(0)

  @@index([employeeId], map: "employee_id")
  @@map("payroll_records")
}

model admins {
  id                  Int          @id @default(autoincrement())
  username            String       @unique(map: "username") @db.VarChar(50)
  password            String       @db.VarChar(255)
  name                String       @db.VarChar(100)
  email               String       @unique(map: "email") @db.VarChar(100)
  role                admins_role? @default(admin)
  created_at          DateTime?    @default(now()) @db.Timestamp(0)
  updated_at          DateTime?    @default(now()) @db.Timestamp(0)
  branch_code         String?      @db.VarChar(10)
  permissions         Json?        @default("[]")
  permissions_enabled Boolean?     @default(false)
  profileImage        String?      @map("profile_image") @db.VarChar(255)
}

model branch_users {
  id          Int       @id @default(autoincrement())
  branch_code String    @db.VarChar(10)
  username    String    @db.VarChar(50)
  password    String    @db.VarChar(255)
  status      String?   @default("Active") @db.VarChar(20)
  created_at  DateTime? @default(now()) @db.Timestamp(0)
  profileImage String?  @map("profile_image") @db.VarChar(255)
}

model branches {
  id             Int       @id @default(autoincrement())
  branch_code    String    @unique(map: "branch_code") @db.VarChar(10)
  branch_name    String    @db.VarChar(100)
  address        String?   @db.Text
  contact_number String?   @db.VarChar(20)
  status         String?   @default("Active") @db.VarChar(20)
  created_at     DateTime? @default(now()) @db.Timestamp(0)
  updated_at     DateTime? @default(now()) @db.Timestamp(0)
}

model notifications {
  id             Int                          @id @default(autoincrement())
  recipient_type notifications_recipient_type @default(admin)
  recipient_id   Int
  type           String                       @db.VarChar(50)
  title          String                       @db.VarChar(255)
  message        String                       @db.Text
  link           String?                      @db.VarChar(255)
  is_read        Boolean?                     @default(false)
  created_at     DateTime?                    @default(now()) @db.Timestamp(0)
  read_at        DateTime?                    @db.Timestamp(0)

  @@index([created_at(sort: Desc)], map: "idx_created")
  @@index([recipient_type, recipient_id], map: "idx_recipient")
  @@index([recipient_type, recipient_id, is_read], map: "idx_unread")
}

model Document {
  id               Int           @id @default(autoincrement())
  employeeId       Int?          @map("employee_id")
  documentType     document_type @map("document_type")
  fileName         String        @map("file_name") @db.VarChar(255)
  originalFileName String?       @map("original_file_name") @db.VarChar(255)
  filePath         String        @map("file_path") @db.VarChar(500)
  fileSize         Int           @map("file_size")
  mimeType         String        @map("mime_type") @db.VarChar(100)
  fileHash         String?       @map("file_hash") @db.VarChar(64)
  isCompressed     Boolean?      @default(false) @map("is_compressed")
  uploadedBy       Int           @map("uploaded_by")
  uploadedAt       DateTime?     @default(now()) @map("uploaded_at") @db.Timestamp(0)
  isArchived       Boolean?      @default(false) @map("is_archived")
  archivedAt       DateTime?     @map("archived_at") @db.Timestamp(0)
  archivedBy       Int?          @map("archived_by")

  @@index([employeeId], map: "idx_document_employee")
  @@index([documentType], map: "idx_document_type")
  @@index([uploadedAt], map: "idx_document_uploaded_at")
  @@index([isArchived], map: "idx_document_is_archived")
  @@map("documents")
}

model ActivityLog {
  id            String                    @id @db.VarChar(50)
  timestamp     DateTime                  @default(now()) @db.DateTime(0)
  userId        Int                       @map("user_id")
  userName      String                    @map("user_name") @db.VarChar(100)
  userRole      String                    @map("user_role") @db.VarChar(50)
  actionType    activity_logs_action_type @map("action_type")
  entityType    activity_logs_entity_type @map("entity_type")
  entityId      String?                   @map("entity_id") @db.VarChar(50)
  entityName    String?                   @map("entity_name") @db.VarChar(200)
  description   String                    @db.Text
  detailsBefore Json?                     @map("details_before")
  detailsAfter  Json?                     @map("details_after")
  changes       Json?
  ipAddress     String?                   @map("ip_address") @db.VarChar(45)
  userAgent     String?                   @map("user_agent") @db.Text
  status        activity_logs_status      @default(SUCCESS)
  metadata      Json?
  branchId      Int?                      @map("branch_id")
  createdAt     DateTime                  @default(now()) @map("created_at") @db.DateTime(0)

  @@index([timestamp], map: "idx_logs_timestamp")
  @@index([userId], map: "idx_logs_user_id")
  @@index([actionType], map: "idx_logs_action_type")
  @@index([entityType], map: "idx_logs_entity_type")
  @@index([status], map: "idx_logs_status")
  @@index([entityId], map: "idx_logs_entity_id")
  @@index([branchId], map: "idx_logs_branch_id")
  @@index([timestamp, actionType], map: "idx_logs_timestamp_action")
  @@map("activity_logs")
}

enum admins_role {
  super_admin
  admin
}

enum attendance_status {
  present
  absent
  late
  half_day
  leave
}

enum payroll_records_status {
  draft
  processed
}

enum document_type {
  RESUME
  SSS
  TIN
  PHILHEALTH
  BIRTH_CERTIFICATE
  PDS
  COVER_LETTER
  APPLICATION_LETTER
  CLEARANCE
}

enum notifications_recipient_type {
  admin
  employee
  role_admin
  role_branch
}

enum activity_logs_action_type {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  SCAN
  APPROVE
  REJECT
  VIEW
}

enum activity_logs_entity_type {
  EMPLOYEE
  ATTENDANCE
  PAYROLL
  SETTINGS
  USER
  BRANCH
  DOCUMENT
}

enum activity_logs_status {
  SUCCESS
  FAILED
  PENDING
}

enum task_status {
  todo
  in_progress
  completed
}

enum task_priority {
  low
  medium
  high
}

model Task {
  id              Int           @id @default(autoincrement())
  title           String        @db.VarChar(255)
  description     String?       @db.Text
  status          task_status   @default(todo)
  priority        task_priority @default(medium)
  dueDate         DateTime?     @map("due_date") @db.Date
  labels          Json?         @default("[]")
  employeeId      Int           @map("employee_id")
  totalTimeSpent  Int           @default(0) @map("total_time_spent")
  isTimerRunning  Boolean       @default(false) @map("is_timer_running")
  lastTimerStart  DateTime?     @map("last_timer_start")
  createdAt       DateTime?     @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime?     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@index([employeeId], map: "idx_task_employee")
  @@index([status], map: "idx_task_status")
  @@index([createdAt], map: "idx_task_created")
  @@map("tasks")
}
