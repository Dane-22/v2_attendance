NODE_ENV=production

# Database
DATABASE_URL="mysql://root:password@localhost:3306/attendance-system"

# Server
PORT=5002

# JWT
JWT_SECRET=3HnIRT8bgu+WEqUcKYnXpY9+BRZ3H7bKnLMK09XZsMs=
JWT_EXPIRES_IN=24h

# QR Code Settings
QR_VERSION=V2
QR_PREFIX=JAJR-EMP

# Rate Limiter Configuration (In-Memory)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS_USER=100
RATE_LIMIT_MAX_REQUESTS_IP=500
RATE_LIMIT_MAX_REQUESTS_GLOBAL=10000
RATE_LIMIT_BURST_PERCENTAGE=20
RATE_LIMIT_ACTION_SCAN=200
RATE_LIMIT_ACTION_DELETE=10
RATE_LIMIT_ACTION_LOGIN=5

# Log Buffer Configuration
LOG_BUFFER_SIZE=100
LOG_BUFFER_FLUSH_INTERVAL_MS=5000
LOG_BUFFER_MAX_MEMORY_MB=100

# Data Retention (Custom per action type)
LOG_RETENTION_LOGIN_DAYS=365
LOG_RETENTION_EMPLOYEE_DAYS=180
LOG_RETENTION_ATTENDANCE_DAYS=90
LOG_RETENTION_PAYROLL_DAYS=365
LOG_RETENTION_DEFAULT_DAYS=90

# WebSocket Configuration
WS_PORT=3001
WS_PATH=/logs-stream

# Sensitive Data Filtering
LOG_FILTER_SALARY=true
LOG_FILTER_PAYROLL=true
LOG_FILTER_CONTACT_DETAILS=true

# Database backup tools configuration
# Windows (local development)
MYSQLDUMP_PATH="C:\\wamp64\\bin\\mysql\\mysql9.6.0\\bin\\mysqldump.exe"
MYSQL_PATH="C:\\wamp64\\bin\\mysql\\mysql9.6.0\\bin\\mysql.exe"

# Production (Linux) - uncomment and adjust as needed
# MYSQLDUMP_PATH="/usr/bin/mysqldump"
# MYSQL_PATH="/usr/bin/mysql"

# Alternative for production if MySQL is in PATH
# MYSQLDUMP_PATH="mysqldump"
# MYSQL_PATH="mysql"

# Email Configuration for Backup Notifications
# SMTP Host (e.g., smtp.gmail.com, smtp.office365.com, smtp.sendgrid.net)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
FROM_EMAIL="noreply@jajr-construction.com"
DEFAULT_RECIPIENTS="admin@jajr-construction.com,backup@jajr-construction.com"

# Notes for email configuration:
# - For Gmail: Use App Password (not regular password) - https://support.google.com/accounts/answer/185833
# - For Office 365: Use your full email and password
# - For SendGrid: Use API key as password
# - For localhost: Use any SMTP service or a local mail server
# - For production: Use a reliable SMTP service (SendGrid, Mailgun, AWS SES, etc.)
